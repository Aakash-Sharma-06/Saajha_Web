{
  "name": "saajha-learning-portal",
  "version": "1.0.0",
  "description": "A Hindi learning portal with stories, math practice, auth, and activity tracking",
  "main": "server.js",
"scripts": {
  "build:css": "tailwindcss -i ./public/src/styles.css -o ./public/output.css",
  "watch:css": "tailwindcss -i ./public/src/styles.css -o ./public/output.css --watch",
  "start": "node server.js",
  "dev": "concurrently \"nodemon server.js\" \"npm run watch:css\""
},
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.1",
    "ejs": "^3.1.6",
    "express": "^4.19.2",
    "express-session": "^1.4.2",
    "mongoose": "^8.9.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2"
  }
}