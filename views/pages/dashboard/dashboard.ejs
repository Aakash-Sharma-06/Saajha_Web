<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">
  <%- include('../../partials/header') %>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="mb-6 rounded-3xl border border-slate-200 bg-linear-to-r from-indigo-600 to-indigo-500 p-8 text-white shadow-lg">
      <h1 class="text-3xl font-bold">नमस्ते, <%= user.name %>!</h1>
      <p class="mt-2 text-indigo-100"><%= user.role === 'host' ? 'आप होस्ट मोड में हैं। किसी स्टूडेंट का नाम या फोन नंबर दर्ज करके उसकी गतिविधि देखें।' : 'आप अपने सीखने का सफ़र आज़ाद ढंग से जारी रख सकते हैं।' %></p>
    </section>
    <% if (isHost) { %>
      <section class="mb-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="mb-3 text-xl font-semibold text-slate-900">स्टूडेंट गतिविधि देखें</h2>
        <form method="GET" action="/dashboard" class="flex flex-wrap gap-3">
          <input class="min-w-60 flex-1 rounded-xl border border-slate-200 px-4 py-3" type="text" name="search" value="<%= searchTerm %>" placeholder="स्टूडेंट का नाम या फोन नंबर लिखें" />
          <button class="rounded-full bg-indigo-600 px-5 py-3 font-semibold text-white transition hover:bg-indigo-700" type="submit">खोजें</button>
        </form>
        <% if (searchTerm) { %>
          <% if (selectedStudent) { %>
            <div class="mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700">
              <strong><%= selectedStudent.name %></strong> की गतिविधि दिख रही है। फोन: <%= selectedStudent.phone || 'कोई फोन नहीं' %>
            </div>
          <% } else { %>
            <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-700">कोई स्टूडेंट नहीं मिला।</div>
          <% } %>
        <% } %>
      </section>
    <% } %>
    <section class="mb-6 grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">कहानियाँ</h3>
        <p class="mt-3 text-3xl font-bold text-indigo-600"><%= storyCount %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">गणित प्रश्न</h3>
        <p class="mt-3 text-3xl font-bold text-indigo-600"><%= questionCount %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">हाल की गतिविधियाँ</h3>
        <p class="mt-3 text-3xl font-bold text-indigo-600"><%= recentActivities.length %></p>
      </div>
    </section>
    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <h2 class="mb-4 text-2xl font-semibold text-slate-900"><%= isHost ? 'स्टूडेंट गतिविधियाँ' : 'ताज़ा गतिविधियाँ' %></h2>
      <% if (recentActivities.length === 0) { %>
        <p class="text-slate-500">अभी कोई गतिविधि नहीं दिखाई दे रही।</p>
      <% } else { %>
        <ul class="space-y-3 text-slate-600">
          <% recentActivities.forEach((activity) => { %>
            <li class="flex flex-col gap-1 border-b border-slate-100 py-3 last:border-0 sm:flex-row sm:items-center sm:justify-between"><span><strong><%= activity.action %></strong> — <%= activity.details %></span><span class="text-sm text-slate-400"><%= new Date(activity.createdAt).toLocaleString('hi-IN') %></span></li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>
</body>
</html>
