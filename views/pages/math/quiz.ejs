<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">
  <%- include('../../partials/header') %>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <form class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm" method="POST" action="/math/quiz/submit">
      <h1 class="mb-6 text-2xl font-semibold text-slate-900">अभ्यास क्विज़</h1>
      <% questions.forEach((question, index) => { %>
        <div class="border-b border-slate-100 py-5 last:border-0">
          <h3 class="mb-3 font-semibold text-slate-800"><%= index + 1 %>. <%= question.prompt %></h3>
          <% question.options.forEach((option) => { %>
            <label class="mb-2 flex items-center gap-2 text-slate-700">
              <input type="radio" name="answer-<%= question._id %>" value="<%= option %>" required />
              <span><%= option %></span>
            </label>
          <% }) %>
        </div>
      <% }) %>
      <button class="mt-6 rounded-full bg-indigo-600 px-5 py-3 font-semibold text-white transition hover:bg-indigo-700" type="submit">जमा करें</button>
    </form>
  </main>
</body>
</html>
