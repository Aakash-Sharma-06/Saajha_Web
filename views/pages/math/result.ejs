<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
  <style>
    /* Falling Stars / Confetti styling */
    .confetti-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      pointer-events: none;
      z-index: 100;
      overflow: hidden;
    }
    .confetti-piece {
      position: absolute;
      top: -20px;
      width: 12px;
      height: 12px;
      background-color: #facc15;
      border-radius: 50%;
      opacity: 0.8;
      animation: fall 4s linear infinite;
    }
    @keyframes fall {
      0% { transform: translateY(-50px) rotate(0deg); opacity: 1; }
      100% { transform: translateY(105vh) rotate(360deg); opacity: 0; }
    }
  </style>
</head>
<body class="min-h-screen text-slate-800 relative pb-12">

  <!-- Confetti Container -->
  <div class="confetti-container" id="confettiBox"></div>

  <!-- Background Ornaments -->
  <svg class="floating-star select-none" style="top: 15%; left: 8%; fill: #facc15;" width="36" height="36" viewBox="0 0 24 24">
    <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/>
  </svg>
  <svg class="floating-star select-none" style="bottom: 25%; right: 7%; fill: #f472b6;" width="30" height="30" viewBox="0 0 24 24">
    <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/>
  </svg>

  <%- include('../../partials/header') %>

  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6 fade-in-page">
    <section class="bubbly-card bg-white p-6 sm:p-10 shadow-[0_8px_0_#1e293b] text-center">
      
      <!-- Celebratory Badge and Title -->
      <div class="mb-8">
        <div class="text-7xl sm:text-8xl animate-bounce-soft select-none inline-block mb-4 filter drop-shadow-[0_4px_6px_rgba(0,0,0,0.15)]">
          <% if (score >= 4) { %>
            🏆
          <% } else if (score >= 3) { %>
            🌟
          <% } else { %>
            👍
          <% } %>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight">
          आपका परिणाम!
        </h1>
        <p class="text-slate-500 font-semibold mt-2">क्विज़ पूरा करने के लिए बधाई!</p>
      </div>

      <!-- Score Box -->
      <div class="bubbly-card bg-pastel-yellow border-3 border-slate-900 p-6 max-w-sm mx-auto shadow-[0_6px_0_#1e293b] mb-8">
        <h2 class="text-xl font-bold text-slate-800">कुल स्कोर</h2>
        <p class="mt-2 text-5xl font-black text-kid-primary animate-float-fast"><%= score %> / <%= total %></p>
        <span class="inline-block mt-3 px-4 py-1.5 rounded-full border-2 border-slate-900 bg-white text-base font-black text-slate-800 shadow-[0_2px_0_#1e293b]">
          <%= badge %>
        </span>
      </div>

      <!-- Answers Review -->
      <div class="text-left mt-8">
        <h3 class="text-xl font-black text-slate-900 mb-4 flex items-center gap-2 border-b-2 border-dashed border-slate-300 pb-3">
          <span>📝</span> आपके उत्तरों की समीक्षा
        </h3>
        
        <div class="space-y-4">
          <% results.forEach((result) => { 
            let cardBg = result.isCorrect ? 'bg-pastel-green border-emerald-300' : 'bg-pastel-pink border-rose-300';
            let cardBorder = result.isCorrect ? 'border-emerald-600' : 'border-rose-600';
            let badgeIcon = result.isCorrect ? '✅' : '❌';
            let badgeText = result.isCorrect ? 'सही उत्तर!' : 'गलत उत्तर!';
            let badgeStyle = result.isCorrect ? 'bg-emerald-200 text-emerald-800 border-emerald-400' : 'bg-rose-200 text-rose-800 border-rose-400';
          %>
            <div class="rounded-3xl border-3 border-slate-900 p-5 shadow-[0_4px_0_#1e293b] <%= cardBg %>">
              <div class="flex items-start justify-between gap-3 mb-3">
                <h4 class="font-extrabold text-slate-800 text-base sm:text-lg leading-relaxed"><%= result.question.prompt %></h4>
                <span class="inline-block rounded-full border px-3 py-0.5 text-xs font-black shrink-0 <%= badgeStyle %>">
                  <%= badgeIcon %> <%= badgeText %>
                </span>
              </div>
              
              <div class="text-sm sm:text-base font-bold text-slate-700 space-y-1">
                <p class="flex items-center gap-1.5">
                  <span>👉</span> आपका उत्तर: <span class="<%= result.isCorrect ? 'text-emerald-700 font-extrabold' : 'text-rose-700 font-extrabold' %>"><%= result.selected || 'कोई उत्तर नहीं' %></span>
                </p>
                <% if (!result.isCorrect) { %>
                  <p class="flex items-center gap-1.5 text-emerald-700">
                    <span>✨</span> सही उत्तर: <span class="font-extrabold"><%= result.question.correctAnswer %></span>
                  </p>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Play Again button -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a class="btn-bubbly btn-bubbly-indigo px-8 py-4 text-white text-base shadow-[0_6px_0_#1e293b] w-full sm:w-auto" href="/math">
          फिर से अभ्यास करें 🎮
        </a>
        <a class="btn-bubbly btn-bubbly-yellow px-8 py-4 text-slate-800 text-base shadow-[0_6px_0_#1e293b] w-full sm:w-auto" href="/dashboard">
          मुख्य डैशबोर्ड 🏠
        </a>
      </div>

    </section>
  </main>

  <!-- Script to dynamically spawn confetti -->
  <script>
    const box = document.getElementById('confettiBox');
    const colors = ['#facc15', '#f472b6', '#38bdf8', '#4ade80', '#fb923c', '#a78bfa'];
    
    // Create random confetti pieces
    function spawnConfetti(count) {
      for (let i = 0; i < count; i++) {
        const div = document.createElement('div');
        div.classList.add('confetti-piece');
        
        // Random positioning & styling
        div.style.left = Math.random() * 100 + 'vw';
        div.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
        div.style.width = (Math.random() * 12 + 6) + 'px';
        div.style.height = div.style.width; // square/circle
        if (Math.random() > 0.5) div.style.borderRadius = '0'; // some squares
        
        // Random animation duration & delay
        div.style.animationDuration = (Math.random() * 3 + 2) + 's';
        div.style.animationDelay = (Math.random() * 2) + 's';
        
        box.appendChild(div);
      }
    }
    
    // Spawn 80 pieces of confetti!
    spawnConfetti(80);
  </script>
</body>
</html>
