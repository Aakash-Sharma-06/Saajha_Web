<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">
  <%- include('../../partials/header') %>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <h1 class="text-2xl font-semibold text-slate-900">आपका परिणाम</h1>
      <p class="mt-3 text-3xl font-bold text-indigo-600">स्कोर: <%= score %>/<%= total %></p>
      <p class="mt-2 text-lg font-medium text-slate-600"><%= badge %></p>
      <div class="mt-6 space-y-4">
        <% results.forEach((result) => { %>
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-4">
            <h3 class="font-semibold text-slate-800"><%= result.question.prompt %></h3>
            <p class="mt-2 text-slate-600">आपका उत्तर: <%= result.selected || 'कोई उत्तर नहीं' %></p>
            <p class="text-slate-600">सही उत्तर: <%= result.question.correctAnswer %></p>
          </div>
        <% }) %>
      </div>
      <a class="mt-6 inline-flex rounded-full bg-indigo-600 px-5 py-3 font-semibold text-white transition hover:bg-indigo-700" href="/math">फिर से अभ्यास करें</a>
    </section>
  </main>
</body>
</html>
