<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">
  <div class="flex min-h-screen items-center justify-center bg-gradient-to-br from-indigo-50 via-white to-slate-100 px-4 py-8">
    <form class="w-full max-w-md rounded-3xl border border-slate-200 bg-white p-8 shadow-xl" method="POST" action="/register">
      <h2 class="mb-6 text-2xl font-bold text-slate-900">रजिस्टर</h2>
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-600"><%= error %></p>
      <% } %>
      <label class="mb-2 block text-sm font-semibold text-slate-700">भूमिका</label>
      <select class="mb-4 w-full rounded-xl border border-slate-200 px-4 py-3 outline-none focus:border-indigo-400" name="role">
        <option value="student">स्टूडेंट</option>
        <option value="host">होस्ट</option>
      </select>
      <label class="mb-2 block text-sm font-semibold text-slate-700">नाम</label>
      <input class="mb-4 w-full rounded-xl border border-slate-200 px-4 py-3 outline-none ring-0 focus:border-indigo-400" type="text" name="name" required />
      <label class="mb-2 block text-sm font-semibold text-slate-700">ईमेल</label>
      <input class="mb-4 w-full rounded-xl border border-slate-200 px-4 py-3 outline-none ring-0 focus:border-indigo-400" type="email" name="email" required />
      <label class="mb-2 block text-sm font-semibold text-slate-700">फोन नंबर</label>
      <input class="mb-4 w-full rounded-xl border border-slate-200 px-4 py-3 outline-none ring-0 focus:border-indigo-400" type="tel" name="phone" />
      <label class="mb-2 block text-sm font-semibold text-slate-700">पासवर्ड</label>
      <input class="mb-5 w-full rounded-xl border border-slate-200 px-4 py-3 outline-none ring-0 focus:border-indigo-400" type="password" name="password" required />
      <button class="w-full rounded-full bg-indigo-600 px-4 py-3 font-semibold text-white transition hover:bg-indigo-700" type="submit">खाता बनाएं</button>
      <p class="mt-4 text-sm text-slate-600">पहले से खाता है? <a class="font-semibold text-indigo-600 hover:text-indigo-700" href="/login">लॉगिन</a></p>
    </form>
  </div>
</body>
</html>
