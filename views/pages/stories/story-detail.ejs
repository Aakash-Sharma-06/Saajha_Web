<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">
  <%- include('../../partials/header') %>
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <h1 class="text-3xl font-semibold text-slate-900"><%= story.title %></h1>
      <span class="mt-3 inline-flex rounded-full bg-indigo-100 px-3 py-1 text-sm font-medium text-indigo-700"><%= story.category %></span>
      <p class="mt-4 text-slate-600"><%= story.summary %></p>
      <h3 class="mt-6 text-xl font-semibold text-slate-900">कहानी ट्रांसक्रिप्ट</h3>
      <p class="mt-3 leading-8 text-slate-700"><%= story.transcript %></p>
      <audio controls class="mt-6 w-full">
        <source src="<%= story.audioUrl %>" type="audio/mpeg" />
        आपका ब्राउज़र ऑडियो चला नहीं सकता।
      </audio>
    </section>
  </main>
  <script>
    const audio = document.querySelector('audio');
    if (audio) {
      audio.addEventListener('play', () => {
        fetch('/stories/<%= story._id %>/play', { method: 'POST' });
      });
    }
  </script>
</body>
</html>
