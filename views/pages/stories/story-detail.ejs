<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="min-h-screen text-slate-800 relative pb-12">

  <!-- Floating Music Notes and Stars -->
  <svg class="floating-star select-none" style="top: 15%; left: 6%; fill: #facc15;" width="36" height="36" viewBox="0 0 24 24">
    <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/>
  </svg>
  <svg class="floating-star select-none" style="bottom: 20%; right: 8%; fill: #38bdf8;" width="28" height="28" viewBox="0 0 24 24">
    <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/>
  </svg>
  
  <!-- Music note ornaments -->
  <span class="floating-pencil text-4xl opacity-50 select-none" style="top: 30%; right: 12%;">🎵</span>
  <span class="floating-book text-4xl opacity-50 select-none" style="bottom: 15%; left: 10%;">🎶</span>

  <%- include('../../partials/header') %>

  <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 fade-in-page">
    
    <!-- Back Button -->
    <div class="mb-6">
      <a href="/stories" class="btn-bubbly btn-bubbly-yellow px-5 py-2 text-sm shadow-[0_4px_0_#1e293b] flex items-center gap-1.5 w-fit">
        <span>⬅️</span> कहानियों पर वापस जाएं
      </a>
    </div>

    <!-- The Giant Open Book Container -->
    <article class="bubbly-card bg-amber-50/70 p-6 sm:p-10 shadow-[0_10px_0_#1e293b] relative overflow-hidden border-3 border-slate-900 rounded-[2.5rem]">
      
      <!-- Top bookmark banner -->
      <div class="absolute top-0 right-8 bg-kid-pink border-x-3 border-b-3 border-slate-900 px-4 py-2.5 text-white font-black text-xs shadow-sm flex items-center gap-1">
        <span>🔖</span> <%= story.category %>
      </div>

      <header class="mb-6 mt-4">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight">
          <%= story.title %>
        </h1>
        <div class="mt-4 p-4 border-2 border-dashed border-slate-400 bg-white/70 rounded-2xl">
          <p class="text-slate-600 font-semibold text-sm sm:text-base leading-relaxed flex items-start gap-2">
            <span class="text-xl shrink-0">📝</span>
            <span><strong>सारांश:</strong> <%= story.summary %></span>
          </p>
        </div>
      </header>

      <!-- Audio Player Box -->
      <section class="my-8 p-5 rounded-2xl border-3 border-slate-900 bg-pastel-blue shadow-[0_4px_0_#1e293b] flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="text-3xl animate-bounce-soft select-none">🔊</span>
          <div>
            <h3 class="font-black text-slate-900 text-lg">कहानी की आवाज़ सुनें</h3>
            <p class="text-xs font-semibold text-slate-500">प्ले बटन दबाएं और आनंद लें!</p>
          </div>
        </div>
        
        <!-- Native Audio styled slightly -->
        <audio controls class="w-full md:max-w-md bg-white border-2 border-slate-900 rounded-full py-1 px-2 shadow-sm">
          <source src="<%= story.audioUrl %>" type="audio/mpeg" />
          आपका ब्राउज़र ऑडियो चला नहीं सकता।
        </audio>
      </section>

      <!-- Story Transcript / Reading space -->
      <section class="prose max-w-none">
        <h2 class="text-xl sm:text-2xl font-black text-slate-900 mb-4 pb-2 border-b-2 border-dashed border-slate-300 flex items-center gap-2">
          <span>📖</span> कहानी पढ़ें
        </h2>
        <div class="bg-white/80 p-6 sm:p-8 rounded-3xl border-2 border-slate-900 shadow-inner leading-8 text-slate-800 text-lg sm:text-xl font-semibold whitespace-pre-line">
          <%= story.transcript %>
        </div>
      </section>

    </article>
  </main>

  <script>
    const audio = document.querySelector('audio');
    if (audio) {
      audio.addEventListener('play', () => {
        fetch('/stories/<%= story._id %>/play', { method: 'POST' });
      });
    }
  </script>
</body>
</html>
