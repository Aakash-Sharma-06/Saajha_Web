<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">

    <!-- Logo -->
    <a href="/dashboard" class="flex items-center gap-3">
      <img
        src="/image.png"
        alt="Saajha Logo"
        class="h-12  w-auto object-contain border border-slate-200 shadow-md flex-shrink-0"
      />
      <!-- <span class="text-xl font-bold text-slate-900">Saajha</span> -->
    </a>

    <!-- Navigation -->
    <nav class="flex items-center gap-6 text-sm font-medium text-slate-700">
      <a href="/dashboard" class="hover:text-amber-600 transition-colors">
        डैशबोर्ड
      </a>

      <a href="/stories" class="hover:text-amber-600 transition-colors">
        कहानियाँ
      </a>

      <a href="/math" class="hover:text-amber-600 transition-colors">
        गणित
      </a>

      <% if (user && user.role === "host") { %>
        <a href="/activity" class="hover:text-amber-600 transition-colors">
          गतिविधि
        </a>
      <% } %>

      <a
        href="/logout"
        class="rounded-full bg-amber-500 px-4 py-2 text-white hover:bg-amber-600 transition-colors"
      >
        लॉगआउट
      </a>
    </nav>

  </div>
</header>